{
  "expo": {
    "name": "無音の演算",
    "slug": "muon-no-enzan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "jp.dentak.whisper-calc",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "音声で計算式を入力するために使用します",
        "NSUbiquitousItemIsExcludedFromBackup": true
      }
    },
    "android": {
      "package": "jp.dentak.whispercalc",
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      ["expo-av", { "microphonePermission": "音声で計算式を入力するために使用します" }],
      "expo-file-system",
      "expo-haptics",
      ["whisper.rn", { "coremlModel": false }]
    ]
  }
}
