# EAS Build - モノレポルートの除外設定
# ReCallKit以外の全アプリ・不要ファイルを除外する

# ---- アプリ: ReCallKit以外を全除外 ----
apps/*
!apps/ReCallKit

# ---- ReCallKit内の不要ファイル ----
apps/ReCallKit/node_modules/
apps/ReCallKit/lambda/
apps/ReCallKit/dist/
apps/ReCallKit/.expo/
apps/ReCallKit/test-results/
apps/ReCallKit/docs/

# ---- モノレポルートの不要ファイル ----
node_modules/
.turbo/
.git/
docs/

# ---- ビルド不要なデータファイル ----
*.csv
apps-*.json
apps-*.md
generate-apps.js
